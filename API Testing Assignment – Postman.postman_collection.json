  "item": [
    {
      "name": "GET Users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();\r",
              "\r",
              "// Log values\r",
              "console.log(\"Total Users:\", response.length);\r",
              "console.log(\"First User Email:\", response[0].email);\r",
              "\r",
              "// Store user ID for chaining\r",
              "pm.collectionVariables.set(\"userId\", response[0].id);\r",
              "\r",
              "// Assertion\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
      "name": "POST Create User",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let randomName = \"User_\" + Math.floor(Math.random() * 1000);\r",
              "let randomEmail = \"user\" + Math.floor(Math.random() * 1000) + \"@test.com\";\r",
              "\r",
              "pm.collectionVariables.set(\"name\", randomName);\r",
              "pm.collectionVariables.set(\"email\", randomEmail);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "let response = pm.response.json();\r",
              "\r",
              "console.log(\"Created User ID:\", response.id);\r",
              "\r",
              "// Save ID for chaining\r",
              "pm.collectionVariables.set(\"createdUserId\", response.id);\r",
              "\r",
              "pm.test(\"User created successfully\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"{{name}}\",\r\n  \"email\": \"{{email}}\"\r\n}\r\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/users\n",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "users\n"
          ]
        }
      },
      "response": []
